# NFT Lending Protocol + Ballet Wallet Support
# Root environment template
#
# Tag legend:
# - [PROD REQUIRED]: must be set for production/testnet deployment.
# - [LOCAL DEFAULT]: safe default for local development.
# - [OPTIONAL]: useful but not strictly required in all deployments.

################################################################################
# 1) ACTIVE NETWORK + RPC CONFIGURATION
################################################################################

# [LOCAL DEFAULT] Active mode consumed by frontend config resolver.
NEXT_PUBLIC_NETWORK_MODE=local

# [LOCAL DEFAULT]
CHAIN_ID_LOCAL=31337
NETWORK_NAME_LOCAL=hardhat-local
RPC_URL_LOCAL=http://127.0.0.1:8545

# [PROD REQUIRED]
CHAIN_ID_TESTNET=11155111
NETWORK_NAME_TESTNET=sepolia
RPC_URL_TESTNET=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# [PROD REQUIRED]
CHAIN_ID_MAINNET=1
NETWORK_NAME_MAINNET=ethereum-mainnet
RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Frontend-compatible RPC keys used in FarmTokenContracts/frontend/lib/contracts.ts
# [LOCAL DEFAULT]
NEXT_PUBLIC_RPC_URL_LOCAL=http://127.0.0.1:8545
NEXT_PUBLIC_RPC_URL_TESTNET=${RPC_URL_TESTNET}
NEXT_PUBLIC_RPC_URL_MAINNET=${RPC_URL_MAINNET}

# [OPTIONAL] Generic fallback key
NEXT_PUBLIC_RPC_URL=${NEXT_PUBLIC_RPC_URL_LOCAL}

################################################################################
# 2) ALCHEMY API + NFT OWNERSHIP DATA
################################################################################

# [PROD REQUIRED] Split keys by network.
ALCHEMY_API_KEY_LOCAL=demo
ALCHEMY_API_KEY_TESTNET=YOUR_ALCHEMY_TESTNET_KEY
ALCHEMY_API_KEY_MAINNET=YOUR_ALCHEMY_MAINNET_KEY

# [LOCAL DEFAULT] Backend currently reads these names.
ALCHEMY_API_KEY=${ALCHEMY_API_KEY_LOCAL}
ALCHEMY_NFT_NETWORK_LOCAL=eth-mainnet
ALCHEMY_NFT_NETWORK_TESTNET=eth-sepolia
ALCHEMY_NFT_NETWORK_MAINNET=eth-mainnet
ALCHEMY_NFT_NETWORK=${ALCHEMY_NFT_NETWORK_LOCAL}

# [LOCAL DEFAULT] Backend JSON-RPC URL currently uses ALCHEMY_URL variable.
ALCHEMY_URL=${RPC_URL_LOCAL}

################################################################################
# 3) SMART CONTRACT ADDRESSES (ALL REQUIRED IN PROD)
################################################################################

# Local deployment from FarmTokenContracts/smart_contracts/deployed_local.json
# [LOCAL DEFAULT]
ORACLE_REGISTRY_ADDRESS_LOCAL=0xCf7Ed3AccA5a467e9e704C703E8D87F634fB0Fc9
VAULT_ADDRESS_LOCAL=0x0165878A594ca255338adfa4d48449f69242Eb8F
LOAN_ENGINE_ADDRESS_LOCAL=0x2279B7A0a67DB372996a5FaB50D91eAA73d2eBe6
DEBT_TOKEN_ADDRESS_LOCAL=0xa513E6E4b8f2a923D98304ec87F64353C4D5C853
REVENUE_DISTRIBUTOR_ADDRESS_LOCAL=0x610178dA211FEF7D417bC0e6FeD39F05609AD788
LICENSE_TOKEN_ADDRESS_LOCAL=0x0000000000000000000000000000000000000000
MULTISIG_WALLET_ADDRESS_LOCAL=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266

# [PROD REQUIRED]
ORACLE_REGISTRY_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
VAULT_ADDRESS_TESTNET=0x99D26fD27C02F2DdDb045eb7C3F98A83E6AC854E
LOAN_ENGINE_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
DEBT_TOKEN_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
REVENUE_DISTRIBUTOR_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
LICENSE_TOKEN_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000
MULTISIG_WALLET_ADDRESS_TESTNET=0x0000000000000000000000000000000000000000

# [PROD REQUIRED]
ORACLE_REGISTRY_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
VAULT_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
LOAN_ENGINE_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
DEBT_TOKEN_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
REVENUE_DISTRIBUTOR_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
LICENSE_TOKEN_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000
MULTISIG_WALLET_ADDRESS_MAINNET=0x0000000000000000000000000000000000000000

# Active backend aliases (backend currently reads ORACLE_REGISTRY_ADDRESS + LOAN_ENGINE_ADDRESS)
# [LOCAL DEFAULT]
ORACLE_REGISTRY_ADDRESS=${ORACLE_REGISTRY_ADDRESS_LOCAL}
LOAN_ENGINE_ADDRESS=${LOAN_ENGINE_ADDRESS_LOCAL}

# Frontend public aliases expected by current app
# [LOCAL DEFAULT]
NEXT_PUBLIC_ORACLE_ADDRESS_LOCAL=${ORACLE_REGISTRY_ADDRESS_LOCAL}
NEXT_PUBLIC_VAULT_ADDRESS_LOCAL=${VAULT_ADDRESS_LOCAL}
NEXT_PUBLIC_LOAN_ENGINE_ADDRESS_LOCAL=${LOAN_ENGINE_ADDRESS_LOCAL}
NEXT_PUBLIC_REVENUE_ROUTER_ADDRESS_LOCAL=${REVENUE_DISTRIBUTOR_ADDRESS_LOCAL}
NEXT_PUBLIC_DEBT_TOKEN_ADDRESS_LOCAL=${DEBT_TOKEN_ADDRESS_LOCAL}

# [PROD REQUIRED]
NEXT_PUBLIC_ORACLE_ADDRESS_TESTNET=${ORACLE_REGISTRY_ADDRESS_TESTNET}
NEXT_PUBLIC_VAULT_ADDRESS_TESTNET=${VAULT_ADDRESS_TESTNET}
NEXT_PUBLIC_LOAN_ENGINE_ADDRESS_TESTNET=${LOAN_ENGINE_ADDRESS_TESTNET}
NEXT_PUBLIC_REVENUE_ROUTER_ADDRESS_TESTNET=${REVENUE_DISTRIBUTOR_ADDRESS_TESTNET}
NEXT_PUBLIC_DEBT_TOKEN_ADDRESS_TESTNET=${DEBT_TOKEN_ADDRESS_TESTNET}

# [PROD REQUIRED]
NEXT_PUBLIC_ORACLE_ADDRESS_MAINNET=${ORACLE_REGISTRY_ADDRESS_MAINNET}
NEXT_PUBLIC_VAULT_ADDRESS_MAINNET=${VAULT_ADDRESS_MAINNET}
NEXT_PUBLIC_LOAN_ENGINE_ADDRESS_MAINNET=${LOAN_ENGINE_ADDRESS_MAINNET}
NEXT_PUBLIC_REVENUE_ROUTER_ADDRESS_MAINNET=${REVENUE_DISTRIBUTOR_ADDRESS_MAINNET}
NEXT_PUBLIC_DEBT_TOKEN_ADDRESS_MAINNET=${DEBT_TOKEN_ADDRESS_MAINNET}

################################################################################
# 4) COLLECTION ADDRESSES (NFT COLLATERAL ALLOWLIST)
################################################################################

# Banksy Gorilla in a Pink Mask collection
# [PROD REQUIRED]
BANKSY_GORILLA_COLLECTION_ADDRESS=0x0c06d6a17eb208a9bc7bd698eb6f22379209e3a4

# [LOCAL DEFAULT]
COLLECTION_ADDRESS=${BANKSY_GORILLA_COLLECTION_ADDRESS}
NEXT_PUBLIC_COLLECTION_ALLOWLIST_LOCAL=${BANKSY_GORILLA_COLLECTION_ADDRESS}
NEXT_PUBLIC_COLLECTION_ALLOWLIST_TESTNET=${BANKSY_GORILLA_COLLECTION_ADDRESS}
NEXT_PUBLIC_COLLECTION_ALLOWLIST_MAINNET=${BANKSY_GORILLA_COLLECTION_ADDRESS}
NEXT_PUBLIC_COLLECTION_ALLOWLIST=${NEXT_PUBLIC_COLLECTION_ALLOWLIST_LOCAL}

################################################################################
# 5) CHAINLINK FEEDS (ETH/USD + NFT FLOOR)
################################################################################

# ETH/USD feed
# [LOCAL DEFAULT] local mock feed from deployment
CHAINLINK_ETH_USD_FEED_LOCAL=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
# [PROD REQUIRED]
CHAINLINK_ETH_USD_FEED_TESTNET=0x694AA1769357215DE4FAC081bf1f309aDC325306
CHAINLINK_ETH_USD_FEED_MAINNET=0x5f4eC3Df9cbd43714FE2740f5E3616155c5b8419

# NFT floor feed (if using a dedicated Chainlink/Data Streams adapter contract)
# [PROD REQUIRED]
CHAINLINK_NFT_FLOOR_FEED_LOCAL=0x0000000000000000000000000000000000000000
CHAINLINK_NFT_FLOOR_FEED_TESTNET=0x0000000000000000000000000000000000000000
CHAINLINK_NFT_FLOOR_FEED_MAINNET=0x0000000000000000000000000000000000000000

################################################################################
# 6) ORACLE UPDATE INTERVALS + LTV PARAMETERS
################################################################################

# Backend loop timing
# [LOCAL DEFAULT]
ORACLE_UPDATE_INTERVAL_SECONDS=60
REQUEST_TIMEOUT_SECONDS=15
MAX_RETRIES=4

# Risk/LTV tuning
# [LOCAL DEFAULT]
TOKEN_IDS=1
TOKEN_QUANTITY=1
TOKEN_WEIGHTING=1

# [PROD REQUIRED] policy knobs
LTV_BASE_BPS_NORMAL=7000
LTV_BASE_BPS_MODERATE_VOL=6000
LTV_BASE_BPS_HIGH_VOL=4000
LTV_HARD_CAP_BPS=9300

################################################################################
# 7) PANIC MODE THRESHOLDS
################################################################################

# Default requested: auto-panic at 85% of liquidation LTV
# [LOCAL DEFAULT]
PANIC_AUTO_TRIGGER_RATIO=0.85
PANIC_AUTO_TRIGGER_BPS=8500
PANIC_RESOLUTION_BUFFER_BPS=500

################################################################################
# 8) DATABASE (POSTGRESQL)
################################################################################

# [LOCAL DEFAULT]
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/nft_lending_local

# [PROD REQUIRED]
DATABASE_URL_PROD=postgresql://USER:PASSWORD@HOST:5432/nft_lending_prod

################################################################################
# 9) AUTH (JWT)
################################################################################

# [PROD REQUIRED] Use a long random secret in production.
JWT_SECRET=replace-with-long-random-secret-at-least-32-bytes
JWT_ISSUER=nft-lending-protocol
JWT_AUDIENCE=nft-lending-admin
JWT_EXPIRES_IN=12h

################################################################################
# 10) BALLET WALLET / WALLETCONNECT
################################################################################

# [PROD REQUIRED]
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=replace-with-walletconnect-project-id

# [OPTIONAL]
NEXT_PUBLIC_APP_NAME=NFT Lending Protocol
NEXT_PUBLIC_APP_DESCRIPTION=Institutional NFT-backed lending with Ballet wallet support
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_APP_ICON=https://example.com/icon.png
NEXT_PUBLIC_MULTISIG_SIGNERS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
NEXT_PUBLIC_MULTISIG_WALLET_ADDRESS=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
NEXT_PUBLIC_SUBGRAPH_URL=

################################################################################
# SIGNER / DEPLOYER / ADMIN (SENSITIVE)
################################################################################

# [LOCAL DEFAULT] Hardhat account #0 (never use in production)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# [PROD REQUIRED]
RESERVE_WALLET=0x0000000000000000000000000000000000000000
ADMIN_WALLET=0x0000000000000000000000000000000000000000

# [OPTIONAL]
ETHERSCAN_API_KEY=replace-with-etherscan-api-key

################################################################################
# BACKEND/FRONTEND BASE URLS
################################################################################

# [LOCAL DEFAULT]
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://127.0.0.1:3000
BACKEND_BASE_URL=http://127.0.0.1:8000
